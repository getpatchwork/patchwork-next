package web

import "github.com/getpatchwork/patchwork/pkg/db"

type breadcrumb struct {
	Label string
	URL   string
}

type pageContext struct {
	User           *db.User
	CSRFToken      string
	Version        string
	CustomCSS      bool
	NavHTML        string
	ProjectNavHTML string
	FooterHTML     string
}

templ layout(title string, crumbs []breadcrumb, pc pageContext) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<title>{ title } - Patchwork</title>
			<link rel="stylesheet" href="/static/style.css"/>
			if pc.CustomCSS {
				<link rel="stylesheet" href="/static/custom.css"/>
			}
		</head>
		<body>
			<header>
				<nav>
					<ul>
						<li><a href="/">Patchwork</a></li>
						for _, c := range crumbs {
							<li>
								if c.URL != "" {
									<a href={ templ.SafeURL(c.URL) }>{ c.Label }</a>
								} else {
									<span>{ c.Label }</span>
								}
							</li>
						}
					</ul>
					<span>
						if pc.User != nil {
							<a href="/user/bundles/">Bundles</a>
							<a href="/user/">{ pc.User.Username }</a>
							<form method="post" action="/user/logout/">
								<input type="hidden" name="csrftoken" value={ pc.CSRFToken }/>
								<button type="submit">Logout</button>
							</form>
						} else {
							<a href="/user/login/">Login</a>
							<a href="/register/">Register</a>
						}
					</span>
				</nav>
				if pc.NavHTML != "" {
					@templ.Raw(pc.NavHTML)
				}
				if pc.ProjectNavHTML != "" {
					@templ.Raw(pc.ProjectNavHTML)
				}
			</header>
			<main>
				{ children... }
			</main>
			<footer>
				Patchwork { pc.Version } | <a href="/api/docs">API</a>
				if pc.FooterHTML != "" {
					@templ.Raw(pc.FooterHTML)
				}
			</footer>
		</body>
	</html>
}
